/* --- Reversenumber.js --- */
(function () {
console.log("2. Numbers from 10 to 1");

for (let i = 10; i >= 1; i--) {
    console.log(i);
}
})();

/* --- sumofnumbers.js --- */
(function () {
console.log("6. Sum of Numbers from 1 to 10");

let sum = 0;

for (let i = 1; i <= 10; i++) {
    sum += i;
}

console.log("Final Sum = " + sum);
})();

